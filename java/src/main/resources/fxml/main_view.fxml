<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.nhom9.atbmtt.DSAController"
            styleClass="root-pane">

    <!-- HEADER -->
    <top>
        <VBox styleClass="header-box" alignment="CENTER" spacing="5">
            <padding><Insets top="20" right="20" bottom="15" left="20"/></padding>
            <Label text="CHỮ KÝ SỐ DSA" styleClass="app-title"/>
            <Label text="Digital Signature Algorithm - Nhóm 9 ATBMTT" styleClass="app-subtitle"/>
            <Separator styleClass="header-separator"/>
        </VBox>
    </top>

    <!-- MAIN CONTENT - TABS -->
    <center>
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" styleClass="main-tab-pane">
            <padding><Insets top="5" right="15" bottom="5" left="15"/></padding>

            <!-- ==================== TAB 1: SINH KHÓA ==================== -->
            <Tab text="1. Sinh Khóa" styleClass="custom-tab">
                <ScrollPane fitToWidth="true" styleClass="tab-scroll">
                    <VBox spacing="15" styleClass="tab-content">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                        <Label text="SINH CẶP KHÓA DSA" styleClass="section-title"/>
                        <Label text="Chọn kích thước khóa và nhấn Sinh Khóa để tạo bộ tham số (p, q, g) và cặp khóa (x, y)" styleClass="section-desc" wrapText="true"/>

                        <!-- Key Size Selection -->
                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <Label text="Kích thước khóa:" styleClass="field-label"/>
                            <ComboBox fx:id="keySizeCombo" styleClass="key-combo" prefWidth="180"/>
                            <Button text="Sinh Khóa" onAction="#handleGenerateKeys" styleClass="btn-primary"/>
                            <ProgressIndicator fx:id="keyProgress" prefWidth="30" prefHeight="30"/>
                        </HBox>

                        <Label fx:id="keyStatusLabel" styleClass="status-label"/>

                        <!-- Key Results -->
                        <VBox fx:id="keyResultBox" spacing="12" styleClass="result-box">
                            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                            
                            <Label text="THAM SỐ HỆ THỐNG" styleClass="result-section-title"/>
                            
                            <!-- Parameter p -->
                            <VBox spacing="3">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="Tham số p (số nguyên tố lớn):" styleClass="param-label"/>
                                    <Label fx:id="pBitLengthLabel" styleClass="bit-length-label"/>
                                </HBox>
                                <TextArea fx:id="paramPArea" editable="false" wrapText="true" prefRowCount="3" styleClass="param-area"/>
                            </VBox>

                            <!-- Parameter q -->
                            <VBox spacing="3">
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label text="Tham số q (ước nguyên tố của p-1):" styleClass="param-label"/>
                                    <Label fx:id="qBitLengthLabel" styleClass="bit-length-label"/>
                                </HBox>
                                <TextArea fx:id="paramQArea" editable="false" wrapText="true" prefRowCount="2" styleClass="param-area"/>
                            </VBox>

                            <!-- Parameter g -->
                            <VBox spacing="3">
                                <Label text="Tham số g (phần tử sinh):" styleClass="param-label"/>
                                <TextArea fx:id="paramGArea" editable="false" wrapText="true" prefRowCount="3" styleClass="param-area"/>
                            </VBox>

                            <Separator styleClass="section-separator"/>

                            <Label text="CẶP KHÓA" styleClass="result-section-title"/>

                            <!-- Private Key -->
                            <VBox spacing="5">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="Khóa bí mật x (Private Key):" styleClass="param-label private-key-label"/>
                                    <Button fx:id="togglePrivateKeyBtn" text="Hiện" onAction="#handleTogglePrivateKey" styleClass="btn-secondary"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button text="Lưu Khóa Bí Mật" onAction="#handleSavePrivateKey" styleClass="btn-secondary"/>
                                </HBox>
                                <TextArea fx:id="privateKeyArea" editable="false" wrapText="true" prefRowCount="2" styleClass="param-area private-key-area"/>
                            </VBox>

                            <!-- Public Key -->
                            <VBox spacing="5">
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="Khóa công khai y = g^x mod p (Public Key):" styleClass="param-label public-key-label"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button text="Lưu Khóa Công Khai" onAction="#handleSavePublicKey" styleClass="btn-secondary"/>
                                </HBox>
                                <TextArea fx:id="publicKeyArea" editable="false" wrapText="true" prefRowCount="3" styleClass="param-area public-key-area"/>
                            </VBox>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </Tab>

            <!-- ==================== TAB 2: KÝ SỐ ==================== -->
            <Tab text="2. Ký Số" styleClass="custom-tab">
                <ScrollPane fitToWidth="true" styleClass="tab-scroll">
                    <VBox spacing="15" styleClass="tab-content">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                        <Label text="KÝ SỐ THÔNG ĐIỆP" styleClass="section-title"/>
                        <Label text="Nhập thông điệp cần ký. Hệ thống sẽ băm bằng SHA-256 và ký bằng khóa bí mật DSA." styleClass="section-desc" wrapText="true"/>

                        <!-- Private Key Loading VBox -->
                        <VBox spacing="8" styleClass="result-box">
                            <padding><Insets top="12" right="15" bottom="12" left="15"/></padding>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="KHÓA DÙNG ĐỂ KÝ" styleClass="result-section-title"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="toggleSignKeyDetailsBtn" text="Xem Chi Tiết" onAction="#handleToggleSignKeyDetails" styleClass="btn-secondary"/>
                                <Button text="Tải Khóa Bí Mật (.txt/.key)" onAction="#handleLoadPrivateKey" styleClass="btn-secondary"/>
                            </HBox>
                            <Label fx:id="signKeyStatusLabel" text="Sử dụng khóa bí mật vừa sinh ở Tab 1 hoặc tải lên khóa mới" styleClass="param-label" style="-fx-text-fill: rgba(255, 255, 255, 0.65);"/>
                            
                            <!-- Detailed parameters -->
                            <VBox fx:id="signKeyDetailsBox" spacing="10" visible="false" managed="false">
                                <Separator styleClass="section-separator"/>
                                <!-- Private Key x -->
                                <VBox spacing="3">
                                    <HBox alignment="CENTER_LEFT" spacing="10">
                                        <Label text="Khóa bí mật x (Private Key):" styleClass="param-label private-key-label"/>
                                        <Button fx:id="toggleSignPrivateKeyBtn" text="Hiện" onAction="#handleToggleSignPrivateKey" styleClass="btn-secondary"/>
                                    </HBox>
                                    <TextArea fx:id="signPrivateKeyArea" editable="false" wrapText="true" prefRowCount="2" styleClass="param-area private-key-area"/>
                                </VBox>
                                <!-- p -->
                                <VBox spacing="3">
                                    <Label text="Tham số p (số nguyên tố lớn):" styleClass="param-label"/>
                                    <TextArea fx:id="signParamPArea" editable="false" wrapText="true" prefRowCount="2" styleClass="param-area"/>
                                </VBox>
                                <!-- q -->
                                <VBox spacing="3">
                                    <Label text="Tham số q (ước nguyên tố của p-1):" styleClass="param-label"/>
                                    <TextArea fx:id="signParamQArea" editable="false" wrapText="true" prefRowCount="2" styleClass="param-area"/>
                                </VBox>
                                <!-- g -->
                                <VBox spacing="3">
                                    <Label text="Tham số g (phần tử sinh):" styleClass="param-label"/>
                                    <TextArea fx:id="signParamGArea" editable="false" wrapText="true" prefRowCount="2" styleClass="param-area"/>
                                </VBox>
                            </VBox>
                        </VBox>

                        <!-- Message Input -->
                        <VBox spacing="5">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="Thông điệp (Message):" styleClass="field-label"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Tải Thông Điệp Từ File" onAction="#handleLoadMessageFile" styleClass="btn-secondary"/>
                            </HBox>
                            <TextArea fx:id="messageArea" promptText="Nhập thông điệp cần ký tại đây hoặc tải từ file..." wrapText="true" prefRowCount="5" styleClass="input-area"/>
                        </VBox>

                        <!-- Action Buttons -->
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button fx:id="signButton" text="Ký Số" onAction="#handleSignAction" styleClass="btn-primary"/>
                            <Button text="Sao Chép" onAction="#handleCopySignature" styleClass="btn-secondary"/>
                            <Button text="Lưu Chữ Ký" onAction="#handleSaveSignature" styleClass="btn-secondary"/>
                            <Button text="Xóa" onAction="#handleClearSign" styleClass="btn-danger"/>
                        </HBox>

                        <Label fx:id="signStatusLabel" styleClass="status-label"/>

                        <!-- Hash Result -->
                        <VBox spacing="5">
                            <Label text="Giá trị băm SHA-256 H(m):" styleClass="field-label"/>
                            <TextArea fx:id="hashArea" editable="false" wrapText="true" prefRowCount="2" styleClass="hash-area"/>
                        </VBox>

                        <!-- Signature Result -->
                        <VBox spacing="5">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="Chữ ký số (Base64 DER):" styleClass="field-label"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="toggleSigDetailsBtn" text="Tách Chữ Ký (r, s)" onAction="#handleToggleSigDetails" styleClass="btn-secondary"/>
                            </HBox>
                            <TextArea fx:id="signatureArea" editable="false" wrapText="true" prefRowCount="3" styleClass="signature-area"/>
                            
                            <!-- Detailed r and s -->
                            <VBox fx:id="sigDetailsBox" spacing="10" visible="false" managed="false" styleClass="result-box">
                                <padding><Insets top="12" right="15" bottom="12" left="15"/></padding>
                                <Label text="THÀNH PHẦN CHỮ KÝ SỐ (r, s)" styleClass="result-section-title"/>
                                
                                <VBox spacing="3">
                                    <Label text="Thành phần r (Hex):" styleClass="param-label"/>
                                    <TextArea fx:id="sigRAreaHex" editable="false" wrapText="true" prefRowCount="2" styleClass="param-area"/>
                                </VBox>
                                <VBox spacing="3">
                                    <Label text="Thành phần r (Decimal):" styleClass="param-label"/>
                                    <TextArea fx:id="sigRAreaDec" editable="false" wrapText="true" prefRowCount="2" styleClass="param-area"/>
                                </VBox>
                                
                                <Separator styleClass="section-separator"/>
                                
                                <VBox spacing="3">
                                    <Label text="Thành phần s (Hex):" styleClass="param-label"/>
                                    <TextArea fx:id="sigSAreaHex" editable="false" wrapText="true" prefRowCount="2" styleClass="param-area"/>
                                </VBox>
                                <VBox spacing="3">
                                    <Label text="Thành phần s (Decimal):" styleClass="param-label"/>
                                    <TextArea fx:id="sigSAreaDec" editable="false" wrapText="true" prefRowCount="2" styleClass="param-area"/>
                                </VBox>
                            </VBox>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </Tab>

            <!-- ==================== TAB 3: XÁC MINH ==================== -->
            <Tab text="3. Xác Minh" styleClass="custom-tab">
                <ScrollPane fitToWidth="true" styleClass="tab-scroll">
                    <VBox spacing="15" styleClass="tab-content">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                        <Label text="XÁC MINH CHỮ KÝ SỐ" styleClass="section-title"/>
                        <Label text="Kiểm tra tính hợp lệ của chữ ký dựa trên khóa công khai (y) và thông điệp gốc." styleClass="section-desc" wrapText="true"/>

                        <!-- Public Key Loading VBox -->
                        <VBox spacing="8" styleClass="result-box">
                            <padding><Insets top="12" right="15" bottom="12" left="15"/></padding>
                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label text="KHÓA DÙNG ĐỂ XÁC MINH" styleClass="result-section-title"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="toggleVerifyKeyDetailsBtn" text="Xem Chi Tiết" onAction="#handleToggleVerifyKeyDetails" styleClass="btn-secondary"/>
                                <Button text="Tải Khóa Công Khai (.txt/.key)" onAction="#handleLoadPublicKey" styleClass="btn-secondary"/>
                            </HBox>
                            <Label fx:id="verifyKeyStatusLabel" text="Sử dụng khóa công khai vừa sinh ở Tab 1 hoặc tải lên khóa mới" styleClass="param-label" style="-fx-text-fill: rgba(255, 255, 255, 0.65);"/>
                            
                            <!-- Detailed parameters -->
                            <VBox fx:id="verifyKeyDetailsBox" spacing="10" visible="false" managed="false">
                                <Separator styleClass="section-separator"/>
                                <!-- Public Key y -->
                                <VBox spacing="3">
                                    <Label text="Khóa công khai y (Public Key):" styleClass="param-label public-key-label"/>
                                    <TextArea fx:id="verifyPublicKeyArea" editable="false" wrapText="true" prefRowCount="2" styleClass="param-area public-key-area"/>
                                </VBox>
                                <!-- p -->
                                <VBox spacing="3">
                                    <Label text="Tham số p (số nguyên tố lớn):" styleClass="param-label"/>
                                    <TextArea fx:id="verifyParamPArea" editable="false" wrapText="true" prefRowCount="2" styleClass="param-area"/>
                                </VBox>
                                <!-- q -->
                                <VBox spacing="3">
                                    <Label text="Tham số q (ước nguyên tố của p-1):" styleClass="param-label"/>
                                    <TextArea fx:id="verifyParamQArea" editable="false" wrapText="true" prefRowCount="2" styleClass="param-area"/>
                                </VBox>
                                <!-- g -->
                                <VBox spacing="3">
                                    <Label text="Tham số g (phần tử sinh):" styleClass="param-label"/>
                                    <TextArea fx:id="verifyParamGArea" editable="false" wrapText="true" prefRowCount="2" styleClass="param-area"/>
                                </VBox>
                            </VBox>
                        </VBox>

                        <!-- Message to Verify -->
                        <VBox spacing="5">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="Thông điệp cần xác minh:" styleClass="field-label"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Tải Thông Điệp Từ File" onAction="#handleLoadVerifyMessageFile" styleClass="btn-secondary"/>
                            </HBox>
                            <TextArea fx:id="verifyMessageArea" promptText="Nhập thông điệp cần xác minh hoặc tải từ file..." wrapText="true" prefRowCount="4" styleClass="input-area"/>
                        </VBox>

                        <!-- Signature to Verify -->
                        <VBox spacing="5">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="Chữ ký số (Base64):" styleClass="field-label"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Tải Chữ Ký Từ File" onAction="#handleLoadVerifySignatureFile" styleClass="btn-secondary"/>
                            </HBox>
                            <TextArea fx:id="verifySignatureArea" promptText="Dán chữ ký số cần xác minh tại đây hoặc tải từ file..." wrapText="true" prefRowCount="4" styleClass="input-area"/>
                        </VBox>

                        <!-- Action Buttons -->
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button fx:id="verifyButton" text="Xác Minh" onAction="#handleVerifyAction" styleClass="btn-verify"/>
                            <Button text="Xóa" onAction="#handleClearVerify" styleClass="btn-danger"/>
                        </HBox>

                        <Label fx:id="verifyStatusLabel" styleClass="status-label" wrapText="true"/>

                        <!-- Verification Result -->
                        <VBox fx:id="verifyResultBox" spacing="10" alignment="CENTER" styleClass="verify-result-box">
                            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                            <Circle fx:id="verifyIndicator" radius="30" styleClass="verify-circle"/>
                            <Label fx:id="verifyResultLabel" styleClass="verify-result-label"/>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </Tab>

            <!-- ==================== TAB 4: HƯỚNG DẪN ==================== -->
            <Tab text="4. Hướng Dẫn" styleClass="custom-tab">
                <ScrollPane fitToWidth="true" styleClass="tab-scroll">
                    <VBox spacing="18" styleClass="tab-content">
                        <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                        <Label text="HƯỚNG DẪN SỬ DỤNG CHI TIẾT" styleClass="section-title"/>
                        <Label text="Cách sử dụng trọn vẹn các tính năng sinh khóa, ký số, xác minh chữ ký DSA" styleClass="section-desc" wrapText="true"/>

                        <!-- Tổng quan -->
                        <VBox spacing="8" styleClass="guide-card">
                            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                            <Label text="DSA là gì?" styleClass="guide-card-title"/>
                            <Label wrapText="true" styleClass="guide-text"
                                   text="DSA (Digital Signature Algorithm) là thuật toán chữ ký số chuẩn hóa quốc gia. Thuật toán này dùng cặp khóa bất đối xứng: khóa bí mật (dùng để ký) và khóa công khai (dùng để xác minh) nhằm đảm bảo tính toàn vẹn của dữ liệu và xác thực người gửi."/>
                        </VBox>

                        <!-- Bước 1 -->
                        <VBox spacing="8" styleClass="guide-card">
                            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                            <Label text="Bước 1 — Sinh &amp; Lưu Trữ Khóa" styleClass="guide-card-title"/>
                            <Label wrapText="true" styleClass="guide-text"
                                   text="• Chọn kích thước (1024 hoặc 2048 bit) và nhấn &quot;Sinh Khóa&quot;. Khóa bí mật (x) mặc định sẽ được ẩn bằng dấu chấm tròn để bảo mật. Nhấn nút &quot;Hiện&quot;/&quot;Ẩn&quot; bên cạnh để xem giá trị Hex của khóa bí mật.&#10;• Nhấn nút &quot;Lưu Khóa Bí Mật&quot; hoặc &quot;Lưu Khóa Công Khai&quot; để lưu khóa thành tệp tin văn bản (.txt) phục vụ cho việc ký và xác minh sau này."/>
                        </VBox>

                        <!-- Bước 2 -->
                        <VBox spacing="8" styleClass="guide-card">
                            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                            <Label text="Bước 2 — Ký Số Thông Điệp" styleClass="guide-card-title"/>
                            <Label wrapText="true" styleClass="guide-text"
                                   text="• Nạp khóa: Nhấn &quot;Tải Khóa Bí Mật&quot; để tải file khóa đã lưu từ trước (hoặc dùng luôn khóa vừa sinh ở Tab 1). Nhấn &quot;Xem Chi Tiết&quot; để đối chiếu tham số p, q, g, x.&#10;• Soạn thông điệp: Nhập chữ trực tiếp hoặc nhấn &quot;Tải Thông Điệp Từ File&quot;.&#10;• Nhấn &quot;Ký Số&quot; để sinh chữ ký Base64 DER.&#10;• Nhấn &quot;Tách Chữ Ký (r, s)&quot; để bóc tách thành phần toán học r và s dưới dạng Hex và Thập phân để kiểm tra.&#10;• Nhấn &quot;Lưu Chữ Ký&quot; để lưu ra file (.sig) hoặc &quot;Sao Chép&quot; vào Clipboard."/>
                        </VBox>

                        <!-- Bước 3 -->
                        <VBox spacing="8" styleClass="guide-card">
                            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                            <Label text="Bước 3 — Xác Minh Chữ Ký" styleClass="guide-card-title"/>
                            <Label wrapText="true" styleClass="guide-text"
                                   text="• Nạp khóa: Nhấn &quot;Tải Khóa Công Khai&quot; để load file khóa công khai cần kiểm tra. Nhấn &quot;Xem Chi Tiết&quot; để kiểm tra tham số p, q, g, y.&#10;• Nạp dữ liệu: Nhấn &quot;Tải Thông Điệp Từ File&quot; và &quot;Tải Chữ Ký Từ File&quot; (hoặc tự dán nội dung chữ ký Base64 vào ô).&#10;• Nhấn &quot;Xác Minh&quot; để đối chiếu phương trình toán học. Hệ thống sẽ bắt lỗi chi tiết nếu sai định dạng Base64, sai cấu trúc DER hoặc sai lệch dữ liệu."/>
                        </VBox>

                        <!-- Lưu ý -->
                        <VBox spacing="8" styleClass="guide-card guide-card-note">
                            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                            <Label text="Lưu ý quan trọng" styleClass="guide-card-title guide-note-title"/>
                            <Label wrapText="true" styleClass="guide-text"
                                   text="• Chữ ký số chỉ hợp lệ với đúng nội dung thông điệp gốc ban đầu. Thay đổi dù chỉ một ký tự hoặc khoảng trắng (hoặc ký tự xuống dòng) cũng sẽ làm kết quả xác minh báo lỗi &quot;CHỮ KÝ KHÔNG HỢP LỆ&quot;.&#10;• Tệp khóa bí mật và khóa công khai lưu ra dạng file văn bản chứa cả thông tin Hex tường minh lẫn định dạng chuỗi Base64 chuẩn hóa để dễ kiểm tra và tích hợp."/>
                        </VBox>

                        <!-- Thông tin nhóm -->
                        <VBox spacing="5" styleClass="guide-card">
                            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                            <Label text="Thông tin dự án" styleClass="guide-card-title"/>
                            <Label wrapText="true" styleClass="guide-text"
                                   text="Nhóm 9 — Môn An Toàn Bảo Mật Thông Tin&#10;Thành viên tham gia: Long &amp; Vi&#10;Phiên bản cải tiến: Khóa học 2025-2026"/>
                        </VBox>

                    </VBox>
                </ScrollPane>
            </Tab>
        </TabPane>
    </center>

    <!-- FOOTER -->
    <bottom>
        <HBox styleClass="footer-box" alignment="CENTER">
            <padding><Insets top="10" right="20" bottom="10" left="20"/></padding>
            <Label fx:id="footerLabel" styleClass="footer-label"/>
        </HBox>
    </bottom>
</BorderPane>
